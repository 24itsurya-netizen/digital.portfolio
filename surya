// ═══ RADAR CHART ═══
(function(){
  const c=document.getElementById('radarCanvas'),ctx=c.getContext('2d');
  const cats=['Frontend','Python','AI/ML','Languages','Hardware','Communication'];
  const vals=[87,92,84,85,90,90];
  const colors=['#1a56b0','#0b1f4b','#0a7ea4','#c9800a','#163a7a','#2d8cf0'];
  const n=cats.length,cx2=c.width/2,cy2=c.height/2,r=105;
  let prog=0;
  const lg=document.getElementById('radarLegend');
  cats.forEach((cat,i)=>{
    lg.innerHTML+=`<div class="rl-item"><div class="rl-dot" style="background:${colors[i]}"></div><div class="rl-name">${cat}</div><div class="rl-track"><div class="rl-fill" id="rl${i}" style="background:${colors[i]}"></div></div><div class="rl-pct">${vals[i]}%</div></div>`;
  });
  const ro=new IntersectionObserver(en=>{en.forEach(e=>{if(e.isIntersecting){anim();cats.forEach((_,i)=>{const el=document.getElementById('rl'+i);if(el)setTimeout(()=>{el.style.width=vals[i]+'%';},i*120);});}});},{threshold:.3});
  ro.observe(c);
  function anim(){if(prog<1)prog+=.025;draw(prog);if(prog<1)requestAnimationFrame(anim);}
  function draw(p){
    ctx.clearRect(0,0,c.width,c.height);
    for(let lv=1;lv<=5;lv++){
      ctx.beginPath();
      for(let i=0;i<n;i++){const a=i/n*Math.PI*2-Math.PI/2,lr=r*lv/5;i===0?ctx.moveTo(cx2+Math.cos(a)*lr,cy2+Math.sin(a)*lr):ctx.lineTo(cx2+Math.cos(a)*lr,cy2+Math.sin(a)*lr);}
      ctx.closePath();ctx.strokeStyle='rgba(11,31,75,.08)';ctx.lineWidth=1;ctx.stroke();
    }
    for(let i=0;i<n;i++){const a=i/n*Math.PI*2-Math.PI/2;ctx.beginPath();ctx.moveTo(cx2,cy2);ctx.lineTo(cx2+Math.cos(a)*r,cy2+Math.sin(a)*r);ctx.strokeStyle='rgba(11,31,75,.1)';ctx.stroke();}
    ctx.beginPath();
    for(let i=0;i<n;i++){const a=i/n*Math.PI*2-Math.PI/2,rv=r*vals[i]/100*p;i===0?ctx.moveTo(cx2+Math.cos(a)*rv,cy2+Math.sin(a)*rv):ctx.lineTo(cx2+Math.cos(a)*rv,cy2+Math.sin(a)*rv);}
    ctx.closePath();ctx.fillStyle='rgba(26,86,176,.1)';ctx.fill();ctx.strokeStyle=colors[0];ctx.lineWidth=2;ctx.stroke();
    for(let i=0;i<n;i++){
      const a=i/n*Math.PI*2-Math.PI/2,rv=r*vals[i]/100*p;
      const x=cx2+Math.cos(a)*rv,y=cy2+Math.sin(a)*rv;
      ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fillStyle=colors[i];ctx.shadowBlur=8;ctx.shadowColor=colors[i];ctx.fill();ctx.shadowBlur=0;
    }
    for(let i=0;i<n;i++){
      const a=i/n*Math.PI*2-Math.PI/2;
      const lx=cx2+Math.cos(a)*(r+18),ly=cy2+Math.sin(a)*(r+18);
      ctx.fillStyle='rgba(107,122,153,.8)';ctx.font='10px Inter,sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(cats[i],lx,ly);
    }
  }
})();

// ═══ P1 NEURAL CANVAS ═══
(function(){
  const c=document.getElementById('p1anim');if(!c)return;
  const ctx=c.getContext('2d');c.width=c.parentElement.offsetWidth||380;c.height=180;
  const layers=[3,5,4,2];const nodes=[];
  layers.forEach((count,li)=>{
    for(let ni=0;ni<count;ni++){
      nodes.push({x:(li+1)*c.width/(layers.length+1),y:(ni+1)*c.height/(count+1),layer:li,pulse:Math.random()*Math.PI*2});
    }
  });
  let t=0;
  function draw(){
    ctx.clearRect(0,0,c.width,c.height);
    nodes.forEach(n=>{
      const nx=nodes.filter(m=>m.layer===n.layer+1);
      nx.forEach(m=>{
        ctx.beginPath();ctx.strokeStyle=`rgba(26,86,176,${0.06+0.07*Math.sin(t*.04+n.pulse)})`;ctx.lineWidth=.8;ctx.moveTo(n.x,n.y);ctx.lineTo(m.x,m.y);ctx.stroke();
      });
    });
    nodes.forEach(n=>{
      const g=0.5+0.5*Math.abs(Math.sin(t*.05+n.pulse));
      ctx.beginPath();ctx.arc(n.x,n.y,4,0,Math.PI*2);ctx.fillStyle=`rgba(26,86,176,${g})`;ctx.shadowBlur=8*g;ctx.shadowColor='rgba(26,86,176,1)';ctx.fill();ctx.shadowBlur=0;
      const pr=6+7*Math.abs(Math.sin(t*.04+n.pulse)),pa=.2*(1-Math.abs(Math.sin(t*.04+n.pulse)));
      ctx.beginPath();ctx.arc(n.x,n.y,pr,0,Math.PI*2);ctx.strokeStyle=`rgba(26,86,176,${pa})`;ctx.lineWidth=.5;ctx.stroke();
    });
    const sp=t%80/80;
    if(nodes.length>5){
      const n1=nodes[0],n2=nodes.find(n=>n.layer===1);
      if(n2){const sx=n1.x+(n2.x-n1.x)*sp,sy=n1.y+(n2.y-n1.y)*sp;ctx.beginPath();ctx.arc(sx,sy,3,0,Math.PI*2);ctx.fillStyle='rgba(201,128,10,.9)';ctx.shadowBlur=10;ctx.shadowColor='rgba(201,128,10,1)';ctx.fill();ctx.shadowBlur=0;}
    }
    t++;requestAnimationFrame(draw);
  }
  draw();
})();

// ═══ P4 CIRCUIT CANVAS ═══
(function(){
  const c=document.getElementById('p4anim');if(!c)return;
  const ctx=c.getContext('2d');c.width=c.parentElement.offsetWidth||380;c.height=180;
  const W=c.width,H=c.height;
  const pts=Array.from({length:20},()=>({x:Math.random()*W,y:Math.random()*H,tick:Math.random()*10}));
  const edges=[];
  for(let i=0;i<pts.length;i++)
    for(let j=i+1;j<pts.length;j++){
      const d=Math.hypot(pts[i].x-pts[j].x,pts[i].y-pts[j].y);
      if(d<85)edges.push({a:i,b:j,sig:null,spd:.025+Math.random()*.025});
    }
  let t=0;
  function draw(){
    ctx.clearRect(0,0,W,H);
    edges.forEach(e=>{
      ctx.beginPath();ctx.moveTo(pts[e.a].x,pts[e.a].y);ctx.lineTo(pts[e.b].x,pts[e.b].y);
      ctx.strokeStyle='rgba(26,86,176,.14)';ctx.lineWidth=1;ctx.stroke();
      if(e.sig!=null){
        e.sig=Math.min(e.sig+e.spd,1);
        const sx=pts[e.a].x+(pts[e.b].x-pts[e.a].x)*e.sig,sy=pts[e.a].y+(pts[e.b].y-pts[e.a].y)*e.sig;
        ctx.beginPath();ctx.arc(sx,sy,3,0,Math.PI*2);ctx.fillStyle='rgba(26,86,176,.9)';ctx.shadowBlur=10;ctx.shadowColor='rgba(26,86,176,1)';ctx.fill();ctx.shadowBlur=0;
        if(e.sig>=1){e.sig=null;pts[e.b].tick=10;}
      }
    });
    pts.forEach(p=>{
      if(p.tick>0)p.tick--;const g=p.tick>0?1:.3;
      ctx.beginPath();ctx.arc(p.x,p.y,p.tick>0?5:3,0,Math.PI*2);ctx.fillStyle=`rgba(26,86,176,${g})`;ctx.shadowBlur=p.tick>0?12:0;ctx.shadowColor='rgba(26,86,176,1)';ctx.fill();ctx.shadowBlur=0;
      ctx.strokeStyle=`rgba(26,86,176,${g*.4})`;ctx.lineWidth=.8;ctx.strokeRect(p.x-6,p.y-6,12,12);
    });
    ctx.fillStyle='rgba(11,31,75,.06)';ctx.fillRect(10,H-24,W-20,16);
    ctx.fillStyle='rgba(26,86,176,.7)';ctx.font='9px JetBrains Mono, monospace';
    ctx.fillText('SYSTEM DIAGNOSTIC: ALL COMPONENTS NOMINAL  ✓',16,H-12);
    if(t%45===0){const e=edges[Math.floor(Math.random()*edges.length)];if(e&&e.sig==null)e.sig=0;}
    t++;requestAnimationFrame(draw);
  }
  draw();
})();

