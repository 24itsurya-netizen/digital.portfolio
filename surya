<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Surya K — Frontend Developer & AI Engineer</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --white:#ffffff;
  --offwhite:#f7f9fc;
  --light:#eef2f8;
  --navy:#0b1f4b;
  --blue:#1a56b0;
  --sky:#2d8cf0;
  --gold:#c9800a;
  --gold-light:#f5a623;
  --teal:#0a7ea4;
  --red:#c0392b;
  --green:#1a7a4a;
  --txt:#1a2340;
  --muted:#6b7a99;
  --border:#dde4f0;
  --shadow:0 4px 24px rgba(11,31,75,.08);
  --shadow-lg:0 12px 48px rgba(11,31,75,.14);
}
html{scroll-behavior:smooth;}
body{background:var(--white);color:var(--txt);font-family:'Inter',sans-serif;overflow-x:hidden;cursor:none;}

/* ═══ CURSOR ═══ */
#cur{position:fixed;width:10px;height:10px;background:var(--blue);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);box-shadow:0 0 0 2px rgba(26,86,176,.2);transition:width .15s,height .15s,background .2s;}
#cur2{position:fixed;width:38px;height:38px;border:1.5px solid rgba(26,86,176,.35);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:transform .1s linear,width .2s,height .2s;}
#cur3{position:fixed;width:70px;height:70px;border:1px solid rgba(26,86,176,.1);border-radius:50%;pointer-events:none;z-index:9997;transform:translate(-50%,-50%);transition:transform .2s linear;}
body:has(a:hover) #cur{width:14px;height:14px;background:var(--gold);}
body:has(a:hover) #cur2{width:52px;height:52px;border-color:rgba(201,128,10,.4);}

/* ═══ PROGRESS ═══ */
#pbar{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--navy),var(--blue),var(--gold));z-index:9990;width:0%;box-shadow:0 1px 8px rgba(26,86,176,.4);}

/* ═══ NAV ═══ */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;justify-content:space-between;align-items:center;
  padding:22px 7%;
  background:rgba(255,255,255,.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  box-shadow:0 1px 16px rgba(11,31,75,.06);
  transition:padding .3s;
}
nav.s{padding:14px 7%;}
.logo{
  font-family:'Playfair Display',serif;font-weight:900;font-size:22px;
  color:var(--navy);text-decoration:none;letter-spacing:-.5px;
}
.logo span{color:var(--blue);}
.nlinks{display:flex;gap:36px;list-style:none;}
.nlinks a{
  font-family:'Inter',sans-serif;font-size:13px;font-weight:500;
  color:var(--muted);text-decoration:none;letter-spacing:.3px;
  position:relative;padding:4px 0;transition:color .3s;
}
.nlinks a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--blue);border-radius:2px;transition:width .3s;}
.nlinks a:hover{color:var(--navy);}
.nlinks a:hover::after{width:100%;}
.nav-cta{
  padding:9px 22px;background:var(--navy);color:#fff;font-size:13px;font-weight:600;
  border:none;cursor:none;text-decoration:none;letter-spacing:.4px;
  border-radius:3px;transition:background .3s,transform .2s;
}
.nav-cta:hover{background:var(--blue);}

/* ═══ SECTIONS ═══ */
section{position:relative;z-index:1;}
.wrap{padding:110px 8%;}
.slabel{
  font-family:'JetBrains Mono',monospace;font-size:11px;
  color:var(--blue);letter-spacing:4px;margin-bottom:12px;
  display:flex;align-items:center;gap:10px;font-weight:500;
}
.slabel::before{content:'';width:28px;height:2px;background:var(--blue);border-radius:2px;}
.stitle{
  font-family:'Playfair Display',serif;
  font-size:clamp(30px,4.5vw,50px);font-weight:900;
  line-height:1.08;letter-spacing:-.5px;margin-bottom:56px;color:var(--navy);
}
.stitle span{color:var(--blue);}

/* ═══ REVEAL ═══ */
.rv{opacity:0;transform:translateY(40px);transition:opacity .75s ease,transform .75s ease;}
.rv.on{opacity:1;transform:translateY(0);}
.rv-l{opacity:0;transform:translateX(-50px);transition:opacity .75s ease,transform .75s ease;}
.rv-l.on{opacity:1;transform:translateX(0);}
.rv-r{opacity:0;transform:translateX(50px);transition:opacity .75s ease,transform .75s ease;}
.rv-r.on{opacity:1;transform:translateX(0);}
.rv-s{opacity:0;transform:scale(.94);transition:opacity .75s ease,transform .75s ease;}
.rv-s.on{opacity:1;transform:scale(1);}

/* ═══ HERO ═══ */
#hero{
  min-height:100vh;display:flex;align-items:center;
  padding:0 8%;position:relative;overflow:hidden;
  background:linear-gradient(135deg,#f0f5ff 0%,#ffffff 50%,#f8fbff 100%);
}
#hero-canvas{position:absolute;inset:0;z-index:0;opacity:.5;}
.hero-deco{
  position:absolute;right:0;top:0;bottom:0;width:45%;
  background:linear-gradient(135deg,var(--navy) 0%,var(--blue) 100%);
  clip-path:polygon(18% 0%,100% 0%,100% 100%,0% 100%);
  opacity:.06;
}
.hero-inner{position:relative;z-index:2;max-width:780px;}

.hero-badge{
  display:inline-flex;align-items:center;gap:10px;
  padding:8px 18px;background:rgba(26,86,176,.08);
  border:1px solid rgba(26,86,176,.18);border-radius:100px;
  font-family:'JetBrains Mono',monospace;font-size:12px;
  color:var(--blue);letter-spacing:1px;margin-bottom:28px;
  animation:slideIn .7s .1s both;
}
.badge-dot{width:8px;height:8px;background:var(--green);border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(26,122,74,.4);}50%{box-shadow:0 0 0 10px rgba(26,122,74,0);}}
@keyframes slideIn{from{opacity:0;transform:translateY(-20px);}to{opacity:1;transform:translateY(0);}}

.hero-name{
  font-family:'Playfair Display',serif;font-weight:900;
  line-height:.92;letter-spacing:-2px;
}
.hero-name .n1{display:block;font-size:clamp(16px,2.5vw,22px);color:var(--muted);font-weight:500;letter-spacing:0;font-family:'Inter',sans-serif;margin-bottom:8px;animation:fadeUp .7s .25s both;}
.hero-name .n2{
  display:block;font-size:clamp(60px,10vw,110px);color:var(--navy);
  animation:fadeUp .7s .35s both;position:relative;
}
.hero-name .n2 .accent{color:var(--blue);}
.hero-name .n3{
  display:block;font-size:clamp(16px,2.5vw,24px);
  color:var(--blue);letter-spacing:3px;font-family:'JetBrains Mono',monospace;
  font-weight:400;margin-top:10px;animation:fadeUp .7s .45s both;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}

.hero-typed{
  margin-top:22px;font-size:17px;color:var(--muted);
  font-family:'JetBrains Mono',monospace;min-height:30px;animation:fadeUp .7s .55s both;
}
.typed-txt{color:var(--blue);font-weight:500;}
.tcur{display:inline-block;width:2px;height:18px;background:var(--blue);vertical-align:middle;margin-left:2px;animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}

.hero-desc{
  margin-top:22px;max-width:540px;font-size:16px;color:var(--muted);
  line-height:1.9;font-weight:400;animation:fadeUp .7s .65s both;
}

.hero-btns{margin-top:38px;display:flex;gap:14px;flex-wrap:wrap;animation:fadeUp .7s .75s both;}
.btn-primary{
  padding:14px 32px;background:var(--navy);color:#fff;
  font-size:14px;font-weight:600;letter-spacing:.5px;
  border:none;cursor:none;text-decoration:none;
  border-radius:3px;transition:background .3s,transform .15s,box-shadow .3s;
  box-shadow:0 4px 14px rgba(11,31,75,.25);
}
.btn-primary:hover{background:var(--blue);box-shadow:0 6px 20px rgba(26,86,176,.35);}
.btn-outline{
  padding:14px 32px;background:transparent;color:var(--navy);
  font-size:14px;font-weight:600;letter-spacing:.5px;
  border:2px solid var(--navy);cursor:none;text-decoration:none;
  border-radius:3px;transition:all .3s;
}
.btn-outline:hover{background:var(--navy);color:#fff;}

.hero-stats{
  margin-top:56px;display:flex;gap:48px;flex-wrap:wrap;
  padding-top:36px;border-top:2px solid var(--border);
  animation:fadeUp .7s .9s both;
}
.stat .snum{font-family:'Playfair Display',serif;font-size:40px;font-weight:900;color:var(--navy);display:block;}
.stat .slbl{font-size:11px;color:var(--muted);letter-spacing:3px;font-weight:500;font-family:'JetBrains Mono',monospace;}

/* ═══ ABOUT ═══ */
#about{background:var(--white);}
.about-g{display:grid;grid-template-columns:1fr 1.4fr;gap:80px;align-items:center;}

/* Professional card */
.prof-card{
  background:linear-gradient(145deg,var(--navy) 0%,#163a7a 100%);
  padding:40px 32px;text-align:center;position:relative;overflow:hidden;
  box-shadow:var(--shadow-lg);
}
.prof-card::before{
  content:'';position:absolute;top:-60px;right:-60px;
  width:180px;height:180px;border-radius:50%;
  background:rgba(255,255,255,.04);
}
.prof-card::after{
  content:'';position:absolute;bottom:-40px;left:-40px;
  width:140px;height:140px;border-radius:50%;
  background:rgba(255,255,255,.03);
}
.card-orbit{
  position:absolute;inset:-32px;border:1px dashed rgba(255,255,255,.1);
  border-radius:50%;animation:orbit 16s linear infinite;
}
.card-orbit::after{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:8px;height:8px;background:var(--gold-light);border-radius:50%;box-shadow:0 0 10px var(--gold-light);}
.card-orbit2{position:absolute;inset:-56px;border:1px dashed rgba(255,255,255,.05);border-radius:50%;animation:orbit 26s linear infinite reverse;}
@keyframes orbit{to{transform:rotate(360deg);}}
.card-avatar{
  width:90px;height:90px;border-radius:50%;
  background:linear-gradient(135deg,var(--sky),var(--gold-light));
  margin:0 auto 16px;display:flex;align-items:center;justify-content:center;
  font-family:'Playfair Display',serif;font-size:36px;font-weight:900;color:#fff;
  box-shadow:0 4px 20px rgba(0,0,0,.3);position:relative;z-index:1;
  animation:float 5s ease-in-out infinite;
}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
.card-name-txt{font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:#fff;margin-bottom:4px;position:relative;z-index:1;}
.card-role-txt{font-size:12px;color:rgba(255,255,255,.55);letter-spacing:2px;font-family:'JetBrains Mono',monospace;position:relative;z-index:1;}
.card-divider{width:40px;height:2px;background:var(--gold-light);margin:16px auto;position:relative;z-index:1;}
.card-stats-row{display:flex;justify-content:center;gap:28px;position:relative;z-index:1;}
.cs-item{display:flex;flex-direction:column;gap:3px;}
.cs-num{font-family:'Playfair Display',serif;font-size:24px;font-weight:900;color:var(--gold-light);}
.cs-lbl{font-size:9px;color:rgba(255,255,255,.45);letter-spacing:2px;font-family:'JetBrains Mono',monospace;}
.card-badge{
  display:inline-flex;align-items:center;gap:6px;margin-top:18px;
  padding:6px 14px;background:rgba(26,122,74,.25);border:1px solid rgba(26,122,74,.4);
  border-radius:100px;font-size:11px;color:rgba(255,255,255,.8);font-family:'JetBrains Mono',monospace;
  position:relative;z-index:1;
}
.cbdot{width:6px;height:6px;background:#4ecca3;border-radius:50%;animation:pulse 2s infinite;}

.about-text h3{font-family:'Playfair Display',serif;font-size:28px;font-weight:900;color:var(--navy);margin-bottom:16px;line-height:1.3;}
.about-text p{font-size:15px;color:var(--muted);line-height:2;margin-bottom:16px;}
.about-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px;}
.pill{
  padding:6px 14px;border:1.5px solid var(--border);
  font-family:'JetBrains Mono',monospace;font-size:11px;
  color:var(--blue);letter-spacing:1px;border-radius:2px;
  background:rgba(26,86,176,.04);transition:all .3s;
}
.pill:hover{background:var(--navy);color:#fff;border-color:var(--navy);}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.ig-item{
  padding:12px 16px;background:var(--offwhite);
  border-left:3px solid var(--blue);
}
.ig-k{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--blue);letter-spacing:2px;margin-bottom:3px;}
.ig-v{font-size:14px;font-weight:600;color:var(--navy);}

/* ═══ SKILLS ═══ */
#skills{background:var(--offwhite);}
.skills-radar-row{display:flex;gap:60px;align-items:center;margin-bottom:44px;flex-wrap:wrap;}
#radarCanvas{flex-shrink:0;}
.radar-legend{display:flex;flex-direction:column;gap:14px;}
.rl-item{display:flex;align-items:center;gap:12px;}
.rl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.rl-name{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--muted);width:90px;}
.rl-track{flex:1;height:4px;background:var(--border);border-radius:4px;min-width:120px;}
.rl-fill{height:100%;width:0;border-radius:4px;transition:width 1.6s cubic-bezier(.77,0,.175,1);}
.rl-pct{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);width:30px;text-align:right;}

.stabs{display:flex;gap:0;margin-bottom:28px;flex-wrap:wrap;border:1.5px solid var(--border);background:var(--white);}
.stab{
  padding:11px 24px;background:transparent;border:none;border-right:1.5px solid var(--border);
  color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:11px;
  letter-spacing:1.5px;cursor:none;transition:all .3s;font-weight:500;
}
.stab:last-child{border-right:none;}
.stab.act{background:var(--navy);color:#fff;}
.stab:not(.act):hover{color:var(--navy);}

.spanel{display:none;}
.spanel.act{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:12px;}
.sk{
  padding:18px 16px;background:var(--white);
  border:1.5px solid var(--border);position:relative;overflow:hidden;
  transition:border-color .3s,transform .3s,box-shadow .3s;cursor:default;
}
.sk::after{
  content:'';position:absolute;bottom:0;left:0;height:3px;width:0%;
  background:linear-gradient(90deg,var(--blue),var(--teal));
  transition:width 1.3s cubic-bezier(.77,0,.175,1);border-radius:0 2px 2px 0;
}
.sk.anim::after{width:var(--lv);}
.sk:hover{border-color:var(--blue);transform:translateY(-4px);box-shadow:0 8px 24px rgba(26,86,176,.1);}
.sk-pct{position:absolute;top:12px;right:12px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--blue);font-weight:600;}
.sk-icon{font-size:22px;margin-bottom:10px;}
.sk-name{font-family:'Inter',sans-serif;font-size:13px;font-weight:700;margin-bottom:3px;color:var(--navy);}
.sk-ver{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);}

/* ═══ PROJECTS ═══ */
#projects{background:var(--white);}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:24px;}
.pc{
  background:var(--white);border:1.5px solid var(--border);
  overflow:hidden;position:relative;cursor:none;
  transition:border-color .35s,box-shadow .35s,transform .25s;
  box-shadow:var(--shadow);
}
.pc:hover{border-color:var(--blue);box-shadow:0 16px 48px rgba(26,86,176,.13);transform:translateY(-4px);}
.pc::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--navy),var(--blue),var(--teal));transform:scaleX(0);transform-origin:left;transition:transform .4s ease;}
.pc:hover::before{transform:scaleX(1);}
.pc-top{height:180px;position:relative;overflow:hidden;background:var(--offwhite);}
.pc-body{padding:26px;}
.pc-num{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:3px;margin-bottom:10px;}
.pc-tag{
  display:inline-block;padding:4px 10px;
  background:rgba(26,86,176,.08);border:1px solid rgba(26,86,176,.2);
  font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--blue);
  margin-bottom:14px;letter-spacing:1px;border-radius:2px;
}
.pc-title{font-family:'Playfair Display',serif;font-size:17px;font-weight:900;margin-bottom:10px;color:var(--navy);line-height:1.35;}
.pc-desc{font-size:13px;color:var(--muted);line-height:1.85;margin-bottom:18px;}
.pc-tech{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
.tch{padding:4px 10px;background:var(--offwhite);border:1px solid var(--border);font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--blue);border-radius:2px;}
.pc-pts{list-style:none;}
.pc-pts li{font-size:13px;color:var(--muted);padding:5px 0;border-bottom:1px solid var(--border);display:flex;gap:8px;line-height:1.7;}
.pc-pts li:last-child{border-bottom:none;}
.pc-pts li::before{content:'→';color:var(--blue);font-weight:700;flex-shrink:0;}

/* Project animations */
#p2anim{position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:center;gap:5px;padding:16px 24px 0;}
.bc{flex:1;max-width:30px;background:linear-gradient(0deg,var(--navy),var(--blue));border-radius:3px 3px 0 0;transform-origin:bottom;animation:bg 2.2s ease infinite alternate;}
.bc:nth-child(1){animation-delay:0s;height:55%;}
.bc:nth-child(2){animation-delay:.1s;height:78%;}
.bc:nth-child(3){animation-delay:.2s;height:45%;}
.bc:nth-child(4){animation-delay:.3s;height:88%;}
.bc:nth-child(5){animation-delay:.4s;height:65%;}
.bc:nth-child(6){animation-delay:.5s;height:42%;}
.bc:nth-child(7){animation-delay:.6s;height:80%;}
.bc:nth-child(8){animation-delay:.7s;height:60%;}
@keyframes bg{0%{transform:scaleY(.75);opacity:.8;}100%{transform:scaleY(1);opacity:1;}}

#p3anim{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.scan-box{width:130px;height:130px;border:2px solid var(--blue);position:relative;box-shadow:0 0 20px rgba(26,86,176,.15);}
.scan-box::before,.scan-box::after{content:'';position:absolute;width:16px;height:16px;border-color:var(--gold);border-style:solid;}
.scan-box::before{top:-2px;left:-2px;border-width:3px 0 0 3px;}
.scan-box::after{bottom:-2px;right:-2px;border-width:0 3px 3px 0;}
.scan-line{position:absolute;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--blue),transparent);top:0;animation:scanAnim 2.5s linear infinite;box-shadow:0 0 8px rgba(26,86,176,.5);}
@keyframes scanAnim{0%{top:0;opacity:1;}90%{top:100%;}100%{top:0;}}
.scan-dots{position:absolute;inset:10px;display:grid;grid-template-columns:repeat(5,1fr);gap:5px;align-items:center;justify-items:center;}
.sdot{width:5px;height:5px;border-radius:50%;background:rgba(26,86,176,.25);animation:sdot 1.8s infinite;}
.sdot:nth-child(2n){animation-delay:.3s;}.sdot:nth-child(3n){animation-delay:.6s;}
@keyframes sdot{0%,100%{opacity:.25;}50%{opacity:1;background:var(--blue);box-shadow:0 0 6px var(--blue);}}
.scan-label{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--blue);letter-spacing:2px;white-space:nowrap;animation:flicker 2s infinite;}
@keyframes flicker{0%,100%{opacity:1;}50%{opacity:.4;}}

/* ═══ EXPERIENCE ═══ */
#experience{background:var(--offwhite);}
.tl{position:relative;padding-left:48px;max-width:900px;margin:0 auto;}
.tl::before{content:'';position:absolute;left:10px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--navy),var(--blue),rgba(26,86,176,0));}
.tlitem{
  position:relative;margin-bottom:44px;padding:30px 32px;
  background:var(--white);border:1.5px solid var(--border);
  box-shadow:var(--shadow);transition:border-color .3s,box-shadow .3s;
}
.tlitem:hover{border-color:var(--blue);box-shadow:var(--shadow-lg);}
.tldot{
  position:absolute;left:-44px;top:32px;
  width:18px;height:18px;border:3px solid var(--blue);
  border-radius:50%;background:var(--white);
  box-shadow:0 0 0 4px rgba(26,86,176,.12);
  display:flex;align-items:center;justify-content:center;
}
.tldot::after{content:'';width:6px;height:6px;background:var(--blue);border-radius:50%;}
.tl-head{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:6px;}
.tl-org{font-family:'Playfair Display',serif;font-size:18px;font-weight:900;color:var(--navy);}
.tl-period{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--blue);padding:5px 12px;background:rgba(26,86,176,.08);border:1px solid rgba(26,86,176,.2);letter-spacing:1px;}
